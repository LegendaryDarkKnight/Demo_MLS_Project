{
  "name": "urbanlease-nyc",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"blue,green\" \"npm run dev --workspace=packages/api\" \"npm run dev --workspace=packages/web\"",
    "build": "npm run build --workspace=packages/api && npm run build --workspace=packages/web",
    "start": "concurrently --names \"API,WEB\" \"npm run start --workspace=packages/api\" \"npm run start --workspace=packages/web\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
